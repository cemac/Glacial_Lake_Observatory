{% extends 'layout.html.j2' %}
{% block styles %}
<!-- datatables style: -->
<link rel="stylesheet"
      type="text/css"
      href="https://cdn.datatables.net/1.11.5/css/jquery.dataTables.min.css"
      media="all">
<!-- leaflet css: -->
<link rel="stylesheet"
      type="text/css"
      href="{{ url_for('static', filename='styles/leaflet.css') }}"
      media="all">
<!-- local css: -->
<link rel="stylesheet"
      type="text/css"
      href="{{ url_for('static', filename='styles/database.css') }}"
      media="all">
<!-- leaflet js: -->
<script src="{{ url_for('static', filename='scripts/leaflet.js') }}"
        charset="utf-8">
</script>
<!-- jquery js: -->
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"
        charset="utf-8">
</script>
<!-- datatables js: -->
<script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"
        charset="utf-8">
</script>
<script src="https://cdn.datatables.net/plug-ins/1.11.5/filtering/type-based/accent-neutralise.js"
        charset="utf-8">
</script>
<!-- local js: -->
<script src="{{ url_for('static', filename='scripts/database.js') }}"
        charset="utf-8"
        defer>
</script>
<!-- local js: -->
<script>
var lakes_data = {{ lakes | replace('None', 'null') }};
</script>
{% endblock %}
{% block body %}
<!-- container: _______________________________________________________ -->
<div id="db_container_col"
     class="db_container_col db_column">
  <!-- header text: ___________________________________________________ -->
  <div id="header_header_row"
       class="db_content_row db_row flex_start">
  </div>
  <!-- lakes map: __________________________________________________ -->
  <div id="map_header_row"
       class="db_content_col db_column flex_start">
    <h2 id="header_db_id"
        class="header_db">Database</h2>
    <p class="db_content_text">Navigate to glacial lakes in the database using the interactive filters and map below, or by searching the datatable.</p>
  </div>
  <div id="map_row"
       class="db_content_row db_row flex_center">
    <div id="lakes_map"
         class="db_map_div flex_grow">
    </div>
  </div>
  <!-- lakes table: ________________________________________________ -->
  <div id="table_header_row"
       class="db_content_row db_row flex_start">
  </div>
  <div id="table_table_row"
       class="db_content_row db_row flex_start">
    <div id="table_table"
         class="page_text">
      <table id="lakes_table"
             class="display">
        <thead>
          <tr>
            <th class="dt-left">GLO ID</th>
            <th class="dt-left th_common_name">Common Name</th>
            <th class="dt-left th_country">Country</th>
            <th class="dt-left th_connectivity">Connectivity</th>
            <th class="dt-left th_area">Area (km²)</th>
            <th class="dt-left th_expansion">Expansion Rate (km²/year)</th>
            <th class="dt-left th_depth">Maximum depth (m)</th>
            <th class="dt-left th_volume">Volume (m³)</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {% for lake in lakes -%}
          <tr class="lakes_table_tr"
              onclick="window.open('/database/lake/{{ lake['GLO_ID'] }}')"
              onmouseenter="open_lake_tt('{{ lake['GLO_ID'] }}')"
              onmouseleave="close_lake_tt('{{ lake['GLO_ID'] }}')">
            <td>{{ lake['GLO_ID'] }}</td>
            <td class="td_common_name">{{ lake['COMMON_NAME'] | replace('None', '') }}</td>
            <td class="td_country">{{ lake['COUNTRY']  }}</td>
            <td class="td_connectivity">{{ lake['CONNECTIVITY']  }}</td>
            {% if lake['AREA'] -%}
              <td class="td_area">{{ lake['AREA'] | round(3) }}</td>
            {% else -%}
              <td class="td_area"></td>
            {% endif -%}
            {% if lake['EXPANSION_RATE'] -%}
              <td class="td_expansion">{{ lake['EXPANSION_RATE'] }}</td>
            {% else -%}
              <td class="td_expansion"></td>
            {% endif -%}
            {% if lake['DEPTH_MAX'] -%}
              <td class="td_depth">{{ lake['DEPTH_MAX'] | round(0) | int() }}</td>
            {% else -%}
              <td class="td_depth"></td>
            {% endif -%}
            {% if lake['VOLUME'] -%}
              <td class="td_volume">{{  "{:0,.0f}".format(lake['VOLUME']) }} ({{ lake['VOLUME_YEAR'] | int() }})</td>
            {% else -%}
              <td class="td_volume"></td>
            {% endif -%}
            <td><a class="lakes_table_a" href="/database/lake/{{ lake['GLO_ID'] }}" target="_blank"></a></td>
          </tr>
          {% endfor -%}
        </tbody>
     </table>
    </div>
  </div>
<!-- end container: ___________________________________________________ -->
</div>
{% endblock %}
